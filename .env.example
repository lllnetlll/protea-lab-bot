# ===== 環境変数の見本（.env.example） =====
# このファイルはGitHubに上げてOK（TOKENは空にしてあるので安全）。
# 実際の値は Railway の Variables 画面に入力します（このファイルを直接使うわけではありません）。
#
# ▼ローカルPCで試したいときだけ、このファイルを「.env」という名前でコピーし、
#   DISCORD_TOKEN に本物のトークンを入れて使ってください（.env は .gitignore で保護済み）。

# botトークン（★絶対に他人に教えない・GitHubに上げない）
DISCORD_TOKEN=ここに本物のトークンを貼る

# アプリのClient ID
DISCORD_CLIENT_ID=1511996724229570641

# サーバー(Guild) ID
DISCORD_GUILD_ID=1481988863995150390

# 通知チャンネルID（#進捗報告）
REMIND_CHANNEL_ID=1504389147077644308

# データ保存先（Railwayでは永続Volumeのパスを指定）
DATA_FILE=/data/data.json

# タイムゾーン（日本時間にする）
TZ=Asia/Tokyo
